"use client"
import { useEffect, useState } from 'react'
import { supabase } from '@/lib/supabase'
import { useRouter } from 'next/navigation'
import { Clock, ShieldCheck, RefreshCw } from 'lucide-react'

export default function WaitingPage() {
  const [isVerified, setIsVerified] = useState(false)
  const router = useRouter()

  // 1. فحص حالة التفعيل تلقائياً كل 5 ثوانٍ
  useEffect(() => {
    const checkStatus = async () => {
      const { data: { user } } = await supabase.auth.getUser()
      if (user) {
        const { data } = await supabase
          .from('profiles')
          .select('verified')
          .eq('id', user.id)
          .single()
        
        if (data?.verified) {
          setIsVerified(true)
          setTimeout(() => router.push('/requests'), 2000) // توجيه بعد نجاح التفعيل
        }
      }
    }

    const interval = setInterval(checkStatus, 5000)
    return () => clearInterval(interval)
  }, [router])

  return (
    <div className="min-h-screen bg-black text-white flex flex-col items-center justify-center p-6 text-center">
      {!isVerified ? (
        <div className="space-y-8 animate-in fade-in duration-700">
          {/* أيقونة الانتظار المتحركة */}
          <div className="relative mx-auto w-24 h-24">
            <div className="absolute inset-0 border-4 border-orange-500/20 rounded-full"></div>
            <div className="absolute inset-0 border-4 border-t-orange-500 rounded-full animate-spin"></div>
            <Clock className="absolute inset-0 m-auto text-orange-500" size={32} />
          </div>

          <div className="space-y-2">
            <h1 className="text-2xl font-bold">جاري مراجعة طلبك...</h1>
            <p className="text-zinc-500 text-sm max-w-[250px] mx-auto">
              بمجرد وصول رسالتك على واتساب، سيقوم فريقنا بتفعيل حسابك فوراً.
            </p>
          </div>

          <div className="bg-zinc-900/50 border border-zinc-800 p-4 rounded-2xl inline-flex items-center gap-2 text-xs text-zinc-400">
            <RefreshCw size={14} className="animate-reverse-spin" />
            يتم التحديث تلقائياً، لا تغلق الصفحة
          </div>
        </div>
      ) : (
        <div className="space-y-6 animate-in zoom-in duration-500">
          <div className="w-24 h-24 bg-green-500 rounded-full flex items-center justify-center mx-auto shadow-[0_0_50px_rgba(34,197,94,0.4)]">
            <ShieldCheck size={48} className="text-black" />
          </div>
          <h1 className="text-3xl font-black text-green-500">تم التفعيل!</h1>
          <p className="text-zinc-400">أهلاً بك في مجتمع Bankak Swap</p>
        </div>
      )}
    </div>
  )
}
